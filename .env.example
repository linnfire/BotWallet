# Pinch Developer Portal keys. Never expose PINCH_CLIENT_SECRET to the browser.

# Public key used by Pinch CaptureJS in the browser
PINCH_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Vite exposes only this key to the frontend
VITE_PINCH_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Backend-only credentials
PINCH_CLIENT_ID=app_test_your_client_id
PINCH_CLIENT_SECRET=sk_test_your_client_secret

# test or live
PINCH_ENV=test

PORT=8000
